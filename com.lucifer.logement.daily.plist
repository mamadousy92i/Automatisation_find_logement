<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
  <dict>
    <key>Label</key>
    <string>com.lucifer.logement.daily</string>

    <key>ProgramArguments</key>
    <array>
      <string>/bin/zsh</string>
      <string>__LOGEMENT_DIR__/run_daily.sh</string>
    </array>

    <key>WorkingDirectory</key>
    <string>__LOGEMENT_DIR__</string>

    <key>RunAtLoad</key>
    <true/>

    <key>StartCalendarInterval</key>
    <dict>
      <key>Hour</key>
      <integer>8</integer>
      <key>Minute</key>
      <integer>0</integer>
    </dict>

    <key>StandardOutPath</key>
    <string>__LOGEMENT_DIR__/logs/launchd.out.log</string>

    <key>StandardErrorPath</key>
    <string>__LOGEMENT_DIR__/logs/launchd.err.log</string>
  </dict>
</plist>
